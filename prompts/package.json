{
  "name": "@editor-extensions/prompts",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "description": "Governed, version-controlled prompt templates for Developer Lightspeed (ISO 42001 A.5.2).",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./manifest": "./manifest.yaml",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "ci": "npx jest",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prebuild": "npm run clean",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts}": "eslint --fix",
    "*.{json,yaml,yml}": "prettier --write"
  },
  "dependencies": {
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "ts-jest": "^29.3.2",
    "tsup": "^8.4.0"
  }
}
