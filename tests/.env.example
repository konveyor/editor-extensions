####################
### EXAMPLE FILE ###
####################

# Do NOT edit this file unless adding new env variables
# Instead, copy it, remove the .example extension and provide your custom values
# For git password please use your generated git token, not a clear text password


############################
### VSCODE CONFIGURATION ###
############################

# Path to executable vscode
# VSCODE_EXECUTABLE_PATH='/usr/share/code/code'

# Local path to VSIX files
# If these and the VSIX_DOWNLOAD_URL variants are not set, the tests will run using the local extension
# under development (launches VS Code with `--extensionDevelopmentPath` and `--enable-proposed-api`).
# CORE_VSIX_FILE_PATH='/path/to/konveyor-core-0.0.0.vsix'
# JAVA_VSIX_FILE_PATH='/path/to/konveyor-java-0.0.0.vsix'
# JAVASCRIPT_VSIX_FILE_PATH='/path/to/konveyor-javascript-0.0.0.vsix'
# GO_VSIX_FILE_PATH='/path/to/konveyor-go-0.0.0.vsix'

# Required only if the extension is not already installed and the corresponding VSIX_FILE_PATH is not defined
# CORE_VSIX_DOWNLOAD_URL='https://github.com/konveyor/editor-extensions/releases/download/v0.0.1/konveyor-core-0.0.1.vsix'
# JAVA_VSIX_DOWNLOAD_URL='https://github.com/konveyor/editor-extensions/releases/download/v0.0.1/konveyor-java-0.0.1.vsix'
# JAVASCRIPT_VSIX_DOWNLOAD_URL='https://github.com/konveyor/editor-extensions/releases/download/v0.0.1/konveyor-javascript-0.0.1.vsix'
# GO_VSIX_DOWNLOAD_URL='https://github.com/konveyor/editor-extensions/releases/download/v0.0.1/konveyor-go-0.0.1.vsix'


##########################
### GENAI PROVIDER API ###
##########################

# OpenAI API key
# OPENAI_API_KEY="XXXXX"

# Google API key for Gemini models
# GOOGLE_API_KEY="XXXXX"


#########################
### TEST REPOSITORIES ###
#########################

# Default REPO used for testing
# TEST_REPO_URL='https://github.com/konveyor-ecosystem/coolstore'
# TEST_REPO_NAME='coolstore'


#########################
### WEB CONFIGURATION ###
#########################

# Set to 1 to run tests in VSCode web environment
# WEB_ENV="1"

# URL of the VSCode web instance (Required if WEB_ENV is 1)
# WEB_BASE_URL="https://devspaces.apps.example.com"

# Login credentials for the web instance (Required if WEB_ENV is 1)
# WEB_LOGIN="username"
# WEB_PASSWORD="password"


############################
### HUB CONFIGURATION ###
############################

# URL of the Konveyor Hub instance for hub configuration tests
# TEST_HUB_URL='https://tackle-konveyor-tackle.apps.example.com/'

# Username for Hub authentication in tests
# TEST_HUB_USERNAME='admin'

# Password for Hub authentication in tests
# TEST_HUB_PASSWORD='password'

# When set to true, enables authentication for Hub in tests
# TEST_HUB_AUTH_ENABLED="true"

# When set to true, skips SSL certificate verification for Hub connections
# TEST_HUB_INSECURE="true"

# Authentication realm for Hub (defaults to 'tackle')
# TEST_HUB_REALM='tackle'


########################
### TEST UTILITIES ###
########################

# URL of the llemulator server for deterministic LLM response testing
# When set, tests use llemulator instead of a real LLM provider
# TEST_LLEMULATOR_URL="http://localhost:8080/v1"

# When set to true, offline tests will run in online mode and generate new cached data
# Will require provider credentials to run
# UPDATE_LLM_CACHE="true"

# Absolute path for custom analyzer binary (used by custom-binary-analysis.test.ts)
# ANALYZER_BINARY_PATH='/path/to/analyzer-lsp'


###########################
### EVALUATION & AWS S3 ###
###########################

# Name of the bucket to store evaluator results
# KAI_QE_S3_BUCKET_NAME="example-bucket-name"
